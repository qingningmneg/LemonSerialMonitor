<Window x:Class="CommMonitor.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:copying="clr-namespace:CommMonitor.Core.Copying;assembly=CommMonitor.Core"
        xmlns:infrastructure="clr-namespace:CommMonitor.App.Infrastructure"
        xmlns:viewModels="clr-namespace:CommMonitor.App.ViewModels"
        mc:Ignorable="d"
        Title="Lemon串口监控"
        Width="1360"
        Height="800"
        MinWidth="980"
        MinHeight="620"
        Background="#FFF7F7F7"
        FontFamily="Microsoft YaHei UI">
    <Window.Resources>
        <infrastructure:PayloadHexConverter x:Key="PayloadHexConverter" />
        <infrastructure:PayloadTextConverter x:Key="PayloadTextConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style TargetType="{x:Type Button}">
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="MinHeight" Value="30" />
        </Style>
        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Margin" Value="2" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Margin" Value="2" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+C"
                    Command="{Binding CopyCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+C"
                    Command="{Binding CopyRawCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="6"
                Background="White"
                BorderBrush="#FFD9D9D9"
                BorderThickness="0,0,0,1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal">
                    <Button Content="刷新端口"
                            Command="{Binding RefreshPortsCommand}" />
                    <TextBlock Margin="8,0,2,0"
                               VerticalAlignment="Center"
                               Text="会话" />
                    <TextBox x:Name="SessionPathBox"
                             Width="160"
                             ToolTip="会话文件名（保存在服务 Sessions 目录中）"
                             Text="{Binding SessionPath, UpdateSourceTrigger=PropertyChanged}" />
                    <Separator Margin="6,3" />
                    <Button Content="开始"
                            Command="{Binding StartCommand}" />
                    <Button Content="暂停"
                            Command="{Binding PauseCommand}" />
                    <Button Content="继续"
                            Command="{Binding ResumeCommand}" />
                    <Button Content="停止"
                            Command="{Binding StopCommand}" />
                    <Button Content="清空"
                            Command="{Binding ClearCommand}" />
                    <Separator Margin="6,3" />
                    <TextBox x:Name="ExportPathBox"
                             Width="130"
                             ToolTip="导出文件名（保存在服务 Exports 目录中）"
                             Text="{Binding ExportPath, UpdateSourceTrigger=PropertyChanged}" />
                    <ComboBox x:Name="ExportFormatSelector"
                              Width="72"
                              SelectedValuePath="Tag"
                              SelectedValue="{Binding ExportFormat, Mode=TwoWay}">
                        <ComboBoxItem Content="CSV" Tag="csv" />
                        <ComboBoxItem Content="TXT" Tag="txt" />
                        <ComboBoxItem Content="RAW" Tag="raw" />
                    </ComboBox>
                    <Button Content="导出"
                            Command="{Binding ExportCommand}" />

                    <Border Margin="10,2,8,2"
                            BorderBrush="#FF356DAA"
                            BorderThickness="1"
                            CornerRadius="3">
                        <DockPanel>
                            <Button x:Name="CopyButton"
                                    DockPanel.Dock="Left"
                                    Margin="0"
                                    Padding="16,5"
                                    Content="复制数据"
                                    Foreground="White"
                                    Background="#FF356DAA"
                                    BorderThickness="0"
                                    Command="{Binding CopyCommand}" />
                            <ComboBox Width="132"
                                      Margin="0"
                                      BorderThickness="0"
                                      SelectedValuePath="Tag"
                                      SelectedValue="{Binding SelectedCopyFormat, Mode=TwoWay}">
                                <ComboBoxItem Content="HEX（空格）"
                                              Tag="{x:Static copying:CopyFormat.HexSpaced}" />
                                <ComboBoxItem Content="HEX（紧凑）"
                                              Tag="{x:Static copying:CopyFormat.HexCompact}" />
                                <ComboBoxItem Content="文本"
                                              Tag="{x:Static copying:CopyFormat.Text}" />
                                <ComboBoxItem Content="C 数组"
                                              Tag="{x:Static copying:CopyFormat.CArray}" />
                                <ComboBoxItem Content="Python bytes"
                                              Tag="{x:Static copying:CopyFormat.PythonBytes}" />
                                <ComboBoxItem Content="TSV"
                                              Tag="{x:Static copying:CopyFormat.Tsv}" />
                                <ComboBoxItem Content="CSV"
                                              Tag="{x:Static copying:CopyFormat.Csv}" />
                                <ComboBoxItem Content="JSON"
                                              Tag="{x:Static copying:CopyFormat.Json}" />
                            </ComboBox>
                        </DockPanel>
                    </Border>

                    <TextBlock Margin="6,0,2,0"
                               VerticalAlignment="Center"
                               Text="查找" />
                    <ComboBox Width="82"
                              SelectedValuePath="Tag"
                              SelectedValue="{Binding SearchType, Mode=TwoWay}">
                        <ComboBoxItem Content="HEX"
                                      Tag="{x:Static viewModels:SearchType.Hex}" />
                        <ComboBoxItem Content="文本"
                                      Tag="{x:Static viewModels:SearchType.Text}" />
                    </ComboBox>
                    <TextBox Width="170"
                             ToolTip="HEX 支持 00-FF 和 ?? 通配符"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="上一个"
                            Command="{Binding PreviousSearchCommand}" />
                    <Button Content="下一个"
                            Command="{Binding NextSearchCommand}" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="8"
                    Padding="10"
                    Background="White"
                    BorderBrush="#FFD9D9D9"
                    BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Margin="0,0,0,8"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Text="监控端口" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="PortChecklist"
                                      ItemsSource="{Binding Ports}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Margin="2,5"
                                              Content="{Binding Name}"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          Background="Transparent" />

            <TabControl x:Name="ViewTabs"
                        Grid.Column="2"
                        Margin="0,8,8,8">
                <TabItem Header="列表">
                    <DataGrid x:Name="CaptureGrid"
                              ItemsSource="{Binding ListViewModel.Events}"
                              SelectedItem="{Binding CurrentEvent, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              EnableColumnVirtualization="True"
                              EnableRowVirtualization="True"
                              IsReadOnly="True"
                              SelectionMode="Extended"
                              SelectionUnit="FullRow"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="#FFF7F9FC"
                              RowBackground="White"
                              BorderThickness="0"
                              ScrollViewer.CanContentScroll="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              infrastructure:SelectedItemsBehavior.SelectedItems="{Binding SelectedEvents}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="70"
                                                Header="序号"
                                                Binding="{Binding Sequence}" />
                            <DataGridTextColumn Width="150"
                                                Header="时间"
                                                Binding="{Binding Timestamp, StringFormat={}{0:HH:mm:ss.fff}}" />
                            <DataGridTextColumn Width="130"
                                                Header="进程"
                                                Binding="{Binding ProcessName}" />
                            <DataGridTextColumn Width="75"
                                                Header="COM"
                                                Binding="{Binding PortName}" />
                            <DataGridTextColumn Width="75"
                                                Header="方向"
                                                Binding="{Binding Kind}" />
                            <DataGridTextColumn Width="105"
                                                Header="操作"
                                                Binding="{Binding IoctlCode, StringFormat=0x{0:X8}}" />
                            <DataGridTextColumn Width="105"
                                                Header="状态"
                                                Binding="{Binding NtStatus, StringFormat=0x{0:X8}}" />
                            <DataGridTextColumn Width="70"
                                                Header="长度"
                                                Binding="{Binding CompletedLength}" />
                            <DataGridTextColumn Width="110"
                                                Header="标志"
                                                Binding="{Binding Flags}" />
                            <DataGridTextColumn Width="2*"
                                                Header="HEX"
                                                Binding="{Binding Payload, Converter={StaticResource PayloadHexConverter}}" />
                            <DataGridTextColumn Width="*"
                                                Header="文本"
                                                Binding="{Binding Payload, Converter={StaticResource PayloadTextConverter}}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
                <TabItem Header="Dump">
                    <DataGrid x:Name="DumpGrid"
                              ItemsSource="{Binding DumpViewModel.Rows}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              EnableRowVirtualization="True"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              FontFamily="Consolas"
                              BorderThickness="0"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="95"
                                                Header="Offset"
                                                Binding="{Binding Offset}" />
                            <DataGridTextColumn Width="*"
                                                Header="HEX"
                                                Binding="{Binding Hex}" />
                            <DataGridTextColumn Width="180"
                                                Header="ASCII"
                                                Binding="{Binding Ascii}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
                <TabItem Header="终端">
                    <DockPanel Background="White">
                        <Border DockPanel.Dock="Top"
                                Padding="6"
                                BorderBrush="#FFD9D9D9"
                                BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Margin="2,0,4,0"
                                           VerticalAlignment="Center"
                                           Text="编码" />
                                <ComboBox x:Name="TerminalEncodingSelector"
                                          Width="110"
                                          ItemsSource="{Binding TerminalViewModel.EncodingChoices}"
                                          SelectedItem="{Binding TerminalViewModel.SelectedEncoding, Mode=TwoWay}" />
                                <CheckBox x:Name="TerminalTimestampToggle"
                                          Margin="10,0,2,0"
                                          VerticalAlignment="Center"
                                          Content="时间"
                                          IsChecked="{Binding TerminalViewModel.ShowTimestamp, Mode=TwoWay}" />
                                <CheckBox x:Name="TerminalPortToggle"
                                          Margin="8,0,2,0"
                                          VerticalAlignment="Center"
                                          Content="端口"
                                          IsChecked="{Binding TerminalViewModel.ShowPort, Mode=TwoWay}" />
                                <CheckBox x:Name="TerminalDirectionToggle"
                                          Margin="8,0,2,0"
                                          VerticalAlignment="Center"
                                          Content="方向"
                                          IsChecked="{Binding TerminalViewModel.ShowDirection, Mode=TwoWay}" />
                                <CheckBox x:Name="TerminalWrapToggle"
                                          Margin="8,0,2,0"
                                          VerticalAlignment="Center"
                                          Content="自动换行"
                                          IsChecked="{Binding TerminalViewModel.Wrap, Mode=TwoWay}" />
                                <CheckBox x:Name="TerminalAutoScrollToggle"
                                          Margin="8,0,2,0"
                                          VerticalAlignment="Center"
                                          Content="自动滚动"
                                          IsChecked="{Binding TerminalViewModel.AutoScroll, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>
                        <ListBox x:Name="TerminalSegmentsList"
                                 ItemsSource="{Binding TerminalViewModel.Segments}"
                                 SelectedItem="{Binding SelectedTerminalSegment, Mode=TwoWay}"
                                 FontFamily="Consolas"
                                 HorizontalContentAlignment="Stretch"
                                 BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling">
                            <ListBox.Style>
                                <Style TargetType="{x:Type ListBox}">
                                    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility"
                                            Value="Disabled" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TerminalViewModel.Wrap}"
                                                     Value="False">
                                            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility"
                                                    Value="Auto" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="{x:Type ListBoxItem}">
                                    <Setter Property="Padding" Value="3,1" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Foreground="{Binding Color}"
                                                   Text="{Binding TimestampPrefix}"
                                                   Visibility="{Binding DataContext.TerminalViewModel.ShowTimestamp, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <TextBlock Grid.Column="1"
                                                   Foreground="{Binding Color}"
                                                   Text="{Binding PortPrefix}"
                                                   Visibility="{Binding DataContext.TerminalViewModel.ShowPort, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <TextBlock Grid.Column="2"
                                                   Foreground="{Binding Color}"
                                                   Text="{Binding DirectionPrefix}"
                                                   Visibility="{Binding DataContext.TerminalViewModel.ShowDirection, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <TextBlock Grid.Column="3"
                                                   Foreground="{Binding Color}"
                                                   Text="{Binding Text}">
                                            <TextBlock.Style>
                                                <Style TargetType="{x:Type TextBlock}">
                                                    <Setter Property="TextWrapping" Value="Wrap" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DataContext.TerminalViewModel.Wrap, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                                                     Value="False">
                                                            <Setter Property="TextWrapping" Value="NoWrap" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </TabItem>
            </TabControl>
        </Grid>

        <StatusBar Grid.Row="2"
                   Background="#FFF0F0F0"
                   BorderBrush="#FFD9D9D9"
                   BorderThickness="0,1,0,0">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="服务：" />
                    <TextBlock x:Name="ServiceStateText"
                               MinWidth="64"
                               Text="{Binding ServiceState}" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="驱动：" />
                    <TextBlock x:Name="DriverStateText"
                               MaxWidth="280"
                               TextTrimming="CharacterEllipsis"
                               Text="{Binding DriverState}" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="事件：" />
                    <TextBlock x:Name="EventCountText"
                               Text="{Binding ListViewModel.EventCount}" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="丢失：" />
                    <TextBlock x:Name="DropCountText"
                               Text="{Binding ListViewModel.DropCount}" />
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="OperationStatusText"
                           Foreground="#FF2E7D32"
                           Text="{Binding OperationStatus}" />
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Foreground="#FFC62828"
                           Text="{Binding Error}" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
